# ── Local development (SQLite, no install required) ──────────────────────────
DATABASE_URL=sqlite:///./naivisense.db

# ── Production (PostgreSQL on Render/Railway) ─────────────────────────────────
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/naivisense

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development

# CORS: "*" for local dev; set to your Flutter web domain in production
# e.g. CORS_ORIGINS=https://naivisense.onrender.com,https://app.naivisense.com
CORS_ORIGINS=*
LOG_LEVEL=INFO
